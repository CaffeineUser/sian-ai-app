# =============================================================================
# .gitignore — Backend Python (FastAPI + Uvicorn)
# =============================================================================

# ── Virtual Environment ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/
.virtualenv/
__pypackages__/

# ── Python Bytecode ──────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# ── Distribution / Build ─────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
*.whl
MANIFEST

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml
*.coveragerc

# ── Type Checking / Linting ──────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12

# ── Database ─────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDEs & Editors ───────────────────────────────────────────────────────────
.idea/
.vscode/
!.vscode/extensions.json
*.suo
*.swp
*.swo

# ── Misc ─────────────────────────────────────────────────────────────────────
*.tmp
*.temp
.cache/
instance/
