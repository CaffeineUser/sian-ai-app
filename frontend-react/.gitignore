# =============================================================================
# .gitignore — Frontend React (Vite + React)
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ── Build Output ──────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.output/
.nuxt/
.next/

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.local

# ── Testing & Coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output/
/test-results/
/playwright-report/
/playwright/.cache/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Cache ─────────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.vite/
*.tsbuildinfo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDEs & Editors ───────────────────────────────────────────────────────────
.idea/
.vscode/
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
